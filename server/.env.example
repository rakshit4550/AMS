PORT=4050
MONGO_URI=mongodb://127.0.0.1:27017/ams
JWT_SECRET=your_jwt_secret_here

# Admin bootstrap (used on server start)
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_on_first_setup
ADMIN_SYNC_CREDENTIALS=false

# Frontend URL used in Forgot Authenticator email links
FRONTEND_URL=http://localhost:3000

EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=AMS Admin <your_email@gmail.com>
TOTP_APP_NAME=myacbook
